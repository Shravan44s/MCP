{
  // OpenCode MCP Server Configuration
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "notion-task-orchestrator": {
      "type": "local",
      "command": ["npx", "tsx", "src/index.ts"],
      "enabled": true
    },
    "ig-mcp": {
      // Instagram MCP server — see https://github.com/jlbadano/ig-mcp
      // Set to true once you fill in your credentials in the environment object below
      "enabled": false,
      "type": "local",
      "command": ["uvx", "ig-mcp"],
      "environment": {
        "INSTAGRAM_ACCESS_TOKEN": "your_access_token_here",
        "INSTAGRAM_BUSINESS_ACCOUNT_ID": "your_business_account_id_here"
      }
    }
  }
}
