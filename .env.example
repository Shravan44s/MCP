# ============================================
# Notion MCP Task Orchestrator - Environment
# ============================================
# Copy this file to .env and fill in your values

# --- Notion ---
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
# The ID of your Notion task database (32-char hex from the URL)
NOTION_DATABASE_ID=your_database_id_here

# --- GitHub ---
# Get from: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- VS Code ---
# Path to the VS Code CLI binary (default: "code")
VSCODE_CLI_PATH=code

# --- Telegram (Optional Notifications / Message Tool) ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Chat ID from @userinfobot
TELEGRAM_CHAT_ID=xxxxxxxxxx

