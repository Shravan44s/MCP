# ============================================
# Notion MCP Task Orchestrator - Environment
# ============================================
# Copy this file to .env and fill in your values

# --- Notion ---
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
# The ID of your Notion task database (32-char hex from the URL)
NOTION_DATABASE_ID=your_database_id_here

# --- GitHub ---
# Get from: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- VS Code ---
# Path to the VS Code CLI binary (default: "code")
VSCODE_CLI_PATH=code

# --- Telegram (Optional Notifications / Message Tool) ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Chat ID from @userinfobot
TELEGRAM_CHAT_ID=xxxxxxxxxx

# --- Instagram (Meta Graph API) ---
# Access token with instagram_content_publish scope
INSTAGRAM_ACCESS_TOKEN=EAAB...
# Connected Instagram Business Account ID
INSTAGRAM_USER_ID=1784...

# --- Google Gemini (Free AI prompt enhancement) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# --- Email Reports (/email command) ---
# Your Gmail address used to send reports
GMAIL_USER=shravanh1144@gmail.com
# Gmail App Password (NOT your regular password!)
# Enable 2FA first, then generate at:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=gnhw dpem mlks uyno
# Recipient email address for the dashboard report
EMAIL_TO=shravanah11@gmail.com

# --- Cron Security ---
CRON_SECRET=your_random_secret_here
